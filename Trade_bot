def ensure_open_trades_columns(df: pd.DataFrame) -> pd.DataFrame:
    out = df.copy()
    for col in OPEN_TRADE_COLUMNS:
        if col not in out.columns:
            out[col] = pd.NA
    return out[OPEN_TRADE_COLUMNS]
def load_open_trades() -> pd.DataFrame:
    if not os.path.exists(OPEN_TRADES_LOG):
        return pd.DataFrame(columns=OPEN_TRADE_COLUMNS)
    try:
        df = pd.read_csv(OPEN_TRADES_LOG, dtype=str)
        if df.empty or len(df.columns) == 0:
            raise ValueError("Empty file")
        return ensure_open_trades_columns(df)
    except Exception:
        print("open_trades_log поврежден или пуст")
        return pd.DataFrame(columns=OPEN_TRADE_COLUMNS)
