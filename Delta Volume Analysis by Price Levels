import pandas as pd
import glob
import os

OUTPUT_CSV = "delta_price_positions_all.csv"
VOLUME_THRESHOLD = 10_000_000
files = glob.glob(os.path.join(os.path.dirname(__file__), "*aggTrades*.csv"))
if not files:
    print(" Файлы aggTrades не найдены!")
    exit()
print(f" Найдено файлов: {len(files)}")
all_results = []
for file in sorted(files):
    print(f" Обрабатываю: {os.path.basename(file)}")    
    df = pd.read_csv(file)    
    df['timestamp'] = pd.to_datetime(df['transact_time'], unit='ms')
    df['price'] = df['price'].astype(float)
    df['qty'] = df['quantity'].astype(float)
    df['usd'] = df['price'] * df['qty']
    df['delta_usd'] = df.apply(
        lambda x: x['usd'] if not x['is_buyer_maker'] else -x['usd'],
        axis=1
    )
    df.set_index('timestamp', inplace=True)
    grouped = (
        df
        .groupby([pd.Grouper(freq='1min'), 'price'])
        .agg(
            delta_usd=('delta_usd', 'sum'),
            total_usd=('usd', 'sum')
        )
        .reset_index()
    )
    idx = grouped.groupby('timestamp')['delta_usd'].apply(
        lambda x: x.abs().idxmax()
    )
    result = grouped.loc[idx].sort_values('timestamp')
    result = result[result['total_usd'] > VOLUME_THRESHOLD]
    result['side'] = result['delta_usd'].apply(lambda x: 'BUY' if x > 0 else 'SELL')        
    all_results.append(result)
# === Объединяем и сохраняем ===
final = pd.concat(all_results).sort_values('timestamp')
final.to_csv(OUTPUT_CSV, index=False)
print(f"Готово: {OUTPUT_CSV} ({len(final)} строк)")


