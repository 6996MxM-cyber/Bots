import pandas as pd
import glob
import os

OUTPUT_CSV = "candles_1m_all.csv"

files = glob.glob(os.path.join(os.path.dirname(__file__), "*aggTrades*.csv"))
if not files:
    print(" Файлы aggTrades не найдены!")
    exit()
print(f" Найдено файлов: {len(files)}")
all_candles = []
for file in sorted(files):
    print(f" Обрабатываю: {os.path.basename(file)}")
    df = pd.read_csv(file)
    df["price"] = df["price"].astype(float)
    df["quantity"] = df["quantity"].astype(float)
    df["buy_qty"] = df.apply(
        lambda x: x["quantity"] if not x["is_buyer_maker"] else 0, axis=1
    )
    df["sell_qty"] = df.apply(
        lambda x: x["quantity"] if x["is_buyer_maker"] else 0, axis=1
    )
    df["timestamp"] = pd.to_datetime(df["transact_time"], unit="ms")
    df = df.set_index("timestamp")
    candles = pd.DataFrame()
    candles["open"]         = df["price"].resample("1min").first()
    candles["high"]         = df["price"].resample("1min").max()
    candles["low"]          = df["price"].resample("1min").min()
    candles["close"]        = df["price"].resample("1min").last()
    candles["volume"]       = df["quantity"].resample("1min").sum()
    candles["buy_volume"]   = df["buy_qty"].resample("1min").sum()
    candles["sell_volume"]  = df["sell_qty"].resample("1min").sum()
    candles["delta"]        = candles["buy_volume"] - candles["sell_volume"]
    candles["trades_count"] = df["price"].resample("1min").count()
    candles = candles.dropna().reset_index()  
    all_candles.append(candles)
final = pd.concat(all_candles).sort_values("timestamp").reset_index(drop=True)
final.to_csv(OUTPUT_CSV, index=False)
print(f"Готово: {OUTPUT_CSV} ({len(final)} строк)")
print(final.head())


